# Plans / notes
.claude/

# UI: built React bundle is regenerated by `make ui`; keep only the .gitkeep
# so //go:embed all:dist compiles before the first build.
internal/ui/dist/*
!internal/ui/dist/.gitkeep
ui/node_modules/
ui/dist/

# GoReleaser build output (binaries, archives, checksums) — produced on release
# and by `goreleaser release --snapshot --clean`.
dist/
