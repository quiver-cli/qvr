# Build artifacts
bin/
*.exe
*.test
*.out
coverage.*

# Go workspace / dependency caches
vendor/
go.work
go.work.sum

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.idea/
.vscode/
*.swp
*~

